{
  "auto_signature_help": true,
  "diff_view_style": "unified",
  "cli_default_open_behavior": "new_window",
  "format_on_save": "on",
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "/opt/homebrew/bin/prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "/opt/homebrew/bin/prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "/opt/homebrew/bin/prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "YAML": {
      "formatter": {
        "external": {
          "command": "/opt/homebrew/bin/prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "Markdown": {
      "formatter": {
        "external": {
          "command": "/opt/homebrew/bin/prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 800,
    },
  },
  "outline_panel": {
    "file_icons": true,
    "dock": "right",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "right",
    "collapse_untracked_diff": false,
  },
  "show_whitespaces": "trailing",
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "disable_ai": true,
  "vim_mode": true,
  "project_panel": {
    "dock": "left",
    "hide_gitignore": true,
  },
  "title_bar": {
    "show_sign_in": false,
    "show_user_menu": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "collaboration_panel": { "dock": "left", "button": false },
  "auto_install_extensions": {
    "gotmpl": true,
  },
}
