{
  "autosave": {
    "after_delay": {
      "milliseconds": 800,
    },
  },
  "outline_panel": {
    "file_icons": true,
    "dock": "right",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "right",
    "collapse_untracked_diff": false,
  },
  "show_whitespaces": "trailing",
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "disable_ai": true,
  "vim_mode": true,
  "project_panel": {
    "dock": "left",
    "hide_gitignore": true,
  },
  "title_bar": {
    "show_sign_in": false,
    "show_user_menu": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "collaboration_panel": { "dock": "left", "button": false },
  "auto_install_extensions": {
    "gotmpl": true,
  },
}
